{
    "name": "Python 3 with Ghidra 12.0.4",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": { 
            "VARIANT": "3.11-bullseye"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "21",
            "jdkDistro": "ms"
        }
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/workspaces/${localWorkspaceFolderBasename}/glyph_venv/bin/python",
                "python.analysis.extraPaths": [
                    "/workspaces/Ghidra/Ghidra/Features/Base/python"
                ],
                "terminal.integrated.env.linux": {
                    "GHIDRA_INSTALL_DIR": "/opt/Ghidra",
                    "PATH": "${env:PATH}:/workspaces/Ghidra/support",
                    "PYTHONPATH": "${containerEnv:PYTHONPATH}:/workspaces/Ghidra/Ghidra/Features/Base/python"
                }
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "ms-toolsai.jupyter",
                "vscjava.vscode-java-pack",
                "ms-python.vscode-python-envs"
            ]
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "chmod +x .devcontainer/setup_ghidra.sh && ./.devcontainer/setup_ghidra.sh"
}