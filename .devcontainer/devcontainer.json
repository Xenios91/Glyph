{
    "name": "Python 3 with Ghidra 12.0.4",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": { 
            "VARIANT": "3.11-bullseye"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "21",
            "jdkDistro": "ms"
        }
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.analysis.extraPaths": [
                    "/workspaces/Ghidra/Ghidra/Features/Base/python"
                ],
                "terminal.integrated.env.linux": {
                    "GHIDRA_INSTALL_DIR": "/workspaces/Ghidra",
                    "PATH": "${env:PATH}:/workspaces/Ghidra/support",
                    "PYTHONPATH": "${containerEnv:PYTHONPATH}:/workspaces/Ghidra/Ghidra/Features/Base/python"
                }
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "ms-toolsai.jupyter",
                "vscjava.vscode-java-pack"
            ]
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "wget https://github.com/NationalSecurityAgency/ghidra/releases/download/Ghidra_12.0.4_build/ghidra_12.0.4_PUBLIC_20260303.zip && unzip ghidra_12.0.4_PUBLIC_20260303.zip && sudo mv ghidra_12.0.4_PUBLIC /opt/Ghidra && rm ghidra_12.0.4_PUBLIC_20260303.zip && python3 -m venv glyph_venv && pip3 install --user -r requirements.txt && export GHIDRA_INSTALL_DIR=/opt/Ghidra"
}